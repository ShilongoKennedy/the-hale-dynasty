  <!-- Hidden source note — for those who read the source -->
  <!--
       For those who look beneath the surface:
       there is one more document. It was not indexed.
       It was not meant to be found.

       the-well.html · Halecroft · 2003
  -->

  <!-- Matilda easter egg overlay — unique, exists nowhere else in the archive -->
  <div class="matilda-overlay" id="matildaOverlay">
    <div class="matilda-overlay-glow"></div>
    <div class="egg-parchment">
      <div class="egg-seal">M·H</div>
      <div class="egg-line-1">&ldquo;Keep asking. Keep the land. See to the pig.&rdquo;</div>
      <div class="egg-line-2">I do not know who will read this. I do not know if the name survives. But if you are reading it, then something did. Something held. I was thirty-seven years old and I had buried my father, my two brothers, and fourteen neighbours in the space of eleven weeks. I was the last one left who knew what the land was called.</div>
      <div class="egg-line-3">I wrote it down. I kept asking. That is all there is. Keep the name. See to the pig. Keep asking.</div>
      <div class="egg-attr">Matilda of Halecroft &nbsp;·&nbsp; c. 1390 &nbsp;·&nbsp; MS. Hale II, fol. 34v<br><em style="color:#2A1A08;">This fragment appears nowhere else in the archive.</em></div>
    </div>
    <div class="egg-dismiss" id="eggDismiss" onclick="dismissMatilda()">Return to the archive</div>
  </div>

  <!-- Pig easter egg overlay — triggered by "see to the pig" in search -->
  <div class="pig-overlay" id="pigOverlay">
    <div class="egg-parchment">
      <div class="egg-seal">H·P</div>
      <div class="egg-line-1">&ldquo;I have said it three times in this document and I will say it again.&rdquo;</div>
      <div class="egg-line-2">It is the oldest running instruction in the archive. In 1348, at the height of the pestilence, four names in the Halecroft death register are followed by the notation &ldquo;see to his pigs&rdquo; &mdash; the last act of bureaucratic care recorded before the ink stops. In 1382 Thomas Hale set it down: <em>keep asking, keep the land, see to the pig</em>. Matilda repeated it in 1390. It appears again, without context, in a Civil War household inventory of 1643. By the time Eleanor Voss reads the letter in 2024, the phrase has outlived every person who ever wrote it.</div>
      <div class="egg-line-3">There has always been a pig. There will always be a pig. This is the longest unbroken thread in nine centuries of record-keeping. See to it.</div>
      <div class="egg-attr">The Hale Archive &nbsp;·&nbsp; Nine centuries &nbsp;·&nbsp; One instruction</div>
    </div>
    <div class="egg-dismiss" onclick="dismissPig()">Return to the archive</div>
  </div>

  <script>
  // ── CINEMATIC INTRO SPLASH ────────────────────────────────────────────────
  (function() {
    var splash = document.getElementById('splash');
    if (!splash) return;
    // Kick off animations on next frame
    requestAnimationFrame(function() {
      requestAnimationFrame(function() { splash.classList.add('go'); });
    });
    // Dismiss after 3.8s — fade out, then remove
    setTimeout(function() {
      splash.classList.add('out');
      setTimeout(function() { splash.style.display = 'none'; }, 1300);
    }, 8500);
    // ── CONFESSION AUDIO ──────────────────────────────────────────────────
    var confAudio = document.getElementById('confessionAudio');
    var audioPlaying = false;

    function fadeAudioIn(){
      confAudio.volume = 0;
      confAudio.play().then(function(){
        audioPlaying = true;
        var vol = 0;
        var fadeIn = setInterval(function(){
          vol = Math.min(vol + 0.015, 0.72);
          confAudio.volume = vol;
          if(vol >= 0.72) clearInterval(fadeIn);
        }, 60);
      }).catch(function(){});
    }

    function fadeAudioOut(cb){
      if(!confAudio || confAudio.paused){ if(cb) cb(); return; }
      var fadeOut = setInterval(function(){
        confAudio.volume = Math.max(0, confAudio.volume - 0.06);
        if(confAudio.volume <= 0){
          clearInterval(fadeOut);
          confAudio.pause();
          audioPlaying = false;
          if(cb) cb();
        }
      }, 80);
    }

    // Sound toggle button on splash
    var soundBtn = document.getElementById('splashSoundBtn');
    var soundIcon = document.getElementById('soundIcon');
    if(soundBtn && confAudio){
      soundBtn.addEventListener('click', function(e){
        e.stopPropagation(); // don't trigger splash skip
        if(audioPlaying){
          fadeAudioOut();
          soundBtn.classList.remove('playing');
          // Switch icon back to muted (X lines)
          soundIcon.innerHTML = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><line x1="23" y1="9" x2="17" y2="15"/><line x1="17" y1="9" x2="23" y2="15"/>';
        } else {
          fadeAudioIn();
          soundBtn.classList.add('playing');
          // Switch icon to sound waves
          soundIcon.innerHTML = '<polygon points="11 5 6 9 2 9 2 15 6 15 11 19 11 5"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/>';
        }
      });
    }

    // Also dismiss on any click/keypress (skip intro)
    function skip() {
      fadeAudioOut();
      splash.classList.add('out');
      setTimeout(function() { splash.style.display = 'none'; }, 600);
      document.removeEventListener('keydown', skip);
      splash.removeEventListener('click', skip);
    }

    setTimeout(function() {
      document.addEventListener('keydown', skip);
      splash.addEventListener('click', skip);
    }, 800);

    // ── PERSISTENT CONFESSION BUTTON (survives splash dismissal) ──────
    // Appears bottom-left after splash fades, mirroring the candle FX btn
    setTimeout(function() {
      var persistBtn = document.createElement('button');
      persistBtn.id = 'hd-confession-btn';
      persistBtn.title = 'A confession — play or pause';
      persistBtn.setAttribute('aria-label', 'Toggle confession audio');
      persistBtn.innerHTML = '&#x266B;';
      var isMobile = window.innerWidth <= 600;
      persistBtn.style.cssText = [
        'position:fixed;',
        isMobile ? 'bottom:max(80px,calc(80px + env(safe-area-inset-bottom)));left:50%;transform:translateX(-50%);' : 'bottom:22px;left:22px;',
        isMobile ? 'width:48px;height:48px;' : 'width:34px;height:34px;',
        'background:rgba(10,7,4,0.85);',
        'border:1px solid rgba(200,168,60,0.3);',
        'border-radius:50%;',
        'color:rgba(200,168,60,0.6);',
        isMobile ? 'font-size:18px;' : 'font-size:15px;',
        'line-height:1;',
        'cursor:pointer;z-index:9995;',
        'display:flex;align-items:center;justify-content:center;',
        'transition:border-color 0.3s,color 0.3s,opacity 0.6s;',
        '-webkit-tap-highlight-color:transparent;touch-action:manipulation;',
        'padding:0;opacity:0;'
      ].join('');
      document.body.appendChild(persistBtn);
      // Fade in after a moment
      requestAnimationFrame(function() {
        requestAnimationFrame(function() { persistBtn.style.opacity = '1'; });
      });
      persistBtn.addEventListener('mouseenter', function() {
        persistBtn.style.borderColor = 'rgba(200,168,60,0.7)';
        persistBtn.style.color = 'rgba(200,168,60,1)';
      });
      persistBtn.addEventListener('mouseleave', function() {
        var playing = confAudio && !confAudio.paused;
        persistBtn.style.borderColor = playing ? 'rgba(200,168,60,0.5)' : 'rgba(200,168,60,0.25)';
        persistBtn.style.color = playing ? 'rgba(200,168,60,0.9)' : 'rgba(200,168,60,0.55)';
      });
      persistBtn.addEventListener('click', function() {
        if (!confAudio) return;
        if (confAudio.paused) {
          fadeAudioIn();
          persistBtn.style.borderColor = 'rgba(200,168,60,0.5)';
          persistBtn.style.color = 'rgba(200,168,60,0.9)';
        } else {
          fadeAudioOut();
          persistBtn.style.borderColor = 'rgba(200,168,60,0.25)';
          persistBtn.style.color = 'rgba(200,168,60,0.55)';
        }
      });
    }, 10200); // appear after splash is fully hidden (8500ms fade-out + 1300ms display:none = 9800ms)

  })();
  </script>

  <script>
  (function() {

    // ─── ARCHIVE DATABASE ──────────────────────────────────────────────────
    var ARCHIVE = [
      {
        ref: 'MS. Hale I',
        title: 'Chronicle of Halecroft — Brother Eadmer, 1121',
        date: '1121',
        href: 'era-I.html',
        excerpt: "Brother Eadmer's account of the Norman Conquest and the founding of the Hale holding. Ranulf de la Hale, 1066–1115. Edwin of Worcester's testimony. Royal Writ, 1086.",
        keys: ['eadmer','chronicle','ranulf','hastings','1066','1121','norman','worcestershire','halecroft','hale','monk','leofric','writ','saxon','edwin','latin','monastery']
      },
      {
        ref: 'MS. Hale II',
        title: 'Parish Death Register and Manor Records',
        date: '1317–1400',
        href: 'era-II.html',
        excerpt: "Death register, Great Mortality, 1348. Thirty-seven deaths in four months. Thomas Hale confirmed in inheritance, 1351. Thomas Hale's Remembrance, 1382: 'Keep asking. Keep the land. See to the pig.'",
        keys: ['plague','death','1348','black death','mortality','famine','thomas hale','1382','remembrance','pig','land','asking','manorial','inquest','1317','1351','father edmund','parish','village']
      },
      {
        ref: 'MS. Hale III',
        title: 'Tudor Correspondence and Household Inventory',
        date: '1534–1560',
        href: 'era-III.html',
        excerpt: "Letters from William Hale, 1534. Household inventory, 1545 — first mention of the oak deed-box. Record of Examination before the bishop's visitors, 1555. Reformation pamphlet.",
        keys: ['tudor','henry','reformation','william hale','inventory','deed-box','1545','bishop','pamphlet','protestant','1555','1534','oak chest','elizabethan']
      },
      {
        ref: 'MS. Hale IV',
        title: 'Civil War Letters and Declaration of Loyalty',
        date: '1642–1665',
        href: 'era-IV.html',
        excerpt: "Eleven letters between John Hale (Parliament) and Thomas Hale (Crown), 1642–1660. Brothers. Different sides. Both survived. Declaration of Loyalty, 1660.",
        keys: ['civil war','parliament','king','royalist','john hale','naseby','1645','restoration','pamphlet','1660','cavalier','cromwell','petition','charles']
      },
      {
        ref: 'MS. Hale V',
        title: 'Memoirs of Sir Nathaniel Hale',
        date: '1671–1744',
        href: 'era-V.html',
        excerpt: "Dictated memoirs, 1744: sardonic, precise, without self-pity. Crump's pencilled annotations in the margin. The baronetcy acquired, 1706. Formal letter to Edmund Hale, 1741.",
        keys: ['nathaniel','georgian','memoir','baronet','1744','crump','sardonic','broadside','1706','1741','announcement','folio','drop cap']
      },
      {
        ref: 'MS. Hale VI',
        title: 'Augusta Hale: Correspondence and Diaries',
        date: '1795–1835',
        href: 'era-VI.html',
        excerpt: "Letters to her solicitor, estate accounts, and diary entries, 1822–1832. Worcester Herald, 1815. An arithmetic of what a woman is permitted. Ironic. Precise.",
        keys: ['augusta','regency','entail','solicitor','diary','ledger','1803','worcester','1815','1822','1832','ironic','alderton','claret','george']
      },
      {
        ref: 'MS. Hale VII',
        title: 'The Edmund Hale Papers',
        date: '1868–1882',
        href: 'era-VII.html',
        excerpt: "Victorian correspondence. A private diary recording an illegitimate son in Brixton. One unsigned confession, undated, on plain white paper. Solicitor's memorandum, death 1882.",
        keys: ['edmund','victorian','confession','illegitimate','1882','locked room','diary','alderton','thomas','mystery','worcester herald','shropshire','black border','brixton']
      },
      {
        ref: 'MS. Hale VIII',
        title: 'Daniel Okafor: Attestation and Field Letters',
        date: '1914–1919',
        href: 'era-VIII.html',
        excerpt: "Attestation paper, 1914. War Office telegram, 24 July 1916: REGRET TO INFORM YOU. Annotation in pencil: 'He lived. Came home 1917.' Thomas Marsh-Hale finds the archive, Oxford, 1919.",
        keys: ['okafor','daniel','war','telegram','thiepval','1916','wwi','attestation','front','somme','west india regiment','1914','1919','archive found','oxford','pencil','wounded','fleet street']
      },
      {
        ref: 'MS. Marsh-Hale I',
        title: 'Edmund Marsh-Hale: Ministry Papers',
        date: '1933–1960',
        href: 'era-IX.html',
        excerpt: "Ministry of Supply memorandum, 1940. Blitz damage assessment, 29 December 1941. Ration book entries, 1943. Personal letter, Edmund to Ruth, 1947.",
        keys: ['ministry','blitz','memo','1940','1941','ration','civil service','harlow','new towns','ration book','structural','1960','ruth','december','post-war','typed']
      },
      {
        ref: 'MS. Marsh-Hale II',
        title: 'James Marsh-Hale and Eleanor Voss: Contemporary Archive',
        date: '2024–2026',
        href: 'era-X.html',
        excerpt: "Email correspondence, January 2024. Eleanor Voss: 'I do not quite know what to do with this.' The archive assembled. Journal: 14 March 2026.",
        keys: ['james','eleanor','2024','contemporary','email','bodleian','voss','oxford','2026','book','james marsh-hale','correspondence','lunch','september','journal','halecroft']
      },
      {
        ref: 'MS. Marsh-Hale 3, item 7',
        title: 'Matilda of Halecroft — Her Letter',
        date: 'c.1390 &nbsp;·&nbsp; TEXT RECOVERED January 2024',
        href: 'era-X.html#matilda',
        special: true,
        excerpt: '"...the line does not end with the sons of William Hale but continues also through his daughter Margery, who married one Thomas Voss of Pershore in the year of Our Lord 1373, and whose line I have followed these thirty years and know to be sound." — Written for whoever reads it last.',
        keys: ['matilda','voss','margery','1373','halecroft','letter','pig','land','asking','pershore','voss family','alice','aelswith','bees','family','your family','recovered','imaging','1390','keeping','asking','see to','see to the pig','six centuries','line','blood','home']
      }
    ];

    // ─── SEARCH LOGIC ─────────────────────────────────────────────────────
    function normalise(s) { return s.toLowerCase().trim(); }

    function scoreDoc(doc, q) {
      var nq = normalise(q);
      var s = 0;
      doc.keys.forEach(function(k) {
        var nk = normalise(k);
        if (nq === nk) s += 12;
        else if (nk.startsWith(nq) || nq.startsWith(nk)) s += 6;
        else if (nk.includes(nq) || nq.includes(nk)) s += 3;
      });
      if (normalise(doc.title).includes(nq)) s += 6;
      if (normalise(doc.excerpt).includes(nq)) s += 4;
      if (doc.special && s > 0) s += 20; // Float Matilda to top when matched
      return s;
    }

    function renderResults(q) {
      var container = document.getElementById('searchResults');
      if (!q || q.length < 2) {
        container.style.display = 'none';
        container.innerHTML = '';
        return;
      }

      var scored = ARCHIVE
        .map(function(doc) { return Object.assign({}, doc, { _score: scoreDoc(doc, q) }); })
        .filter(function(d) { return d._score > 0; })
        .sort(function(a, b) { return b._score - a._score; });

      container.style.display = 'block';

      if (scored.length === 0) {
        container.innerHTML = '<div class="no-results">0 documents found for &ldquo;' + q + '&rdquo;. &nbsp; Try: Voss &nbsp;&middot;&nbsp; plague &nbsp;&middot;&nbsp; Matilda &nbsp;&middot;&nbsp; telegram &nbsp;&middot;&nbsp; confession &nbsp;&middot;&nbsp; pig</div>';
        return;
      }

      var html = '<div class="result-count">' + scored.length + ' document' + (scored.length > 1 ? 's' : '') + ' found in MSS. Hale-Marsh</div>';

      scored.forEach(function(doc) {
        html += '<a class="result-card' + (doc.special ? ' result-card--special' : '') + '" href="' + doc.href + '">';
        html +=   '<div class="result-ref">' + doc.ref + '</div>';
        html +=   '<div class="result-title">' + doc.title + '</div>';
        html +=   '<div class="result-date">' + doc.date + '</div>';
        html +=   '<div class="result-excerpt">' + doc.excerpt + '</div>';
        if (doc.special) {
          html += '<div class="result-alert">⚠ &nbsp; This document was written for you.</div>';
        }
        html +=   '<div class="result-open">→ Open document</div>';
        html += '</a>';
      });

      container.innerHTML = html;
    }

    // ─── MATILDA EASTER EGG ────────────────────────────────────────────────
    var matildaTriggered = false;

    function triggerMatilda() {
      if (matildaTriggered) return;
      matildaTriggered = true;
      var overlay = document.getElementById('matildaOverlay');
      if (!overlay) return;
      overlay.classList.add('active');
      // Also dismiss on pressing Escape
      document.addEventListener('keydown', function onEsc(e) {
        if (e.key === 'Escape') { dismissMatilda(); document.removeEventListener('keydown', onEsc); }
      });
    }

    window.dismissMatilda = function() {
      var overlay = document.getElementById('matildaOverlay');
      if (!overlay) return;
      overlay.style.transition = 'opacity 1s ease';
      overlay.style.opacity = '0';
      setTimeout(function() {
        overlay.classList.remove('active');
        overlay.style.opacity = '';
        overlay.style.transition = '';
        // Clear the search bar
        var inp = document.getElementById('archiveSearch');
        if (inp) { inp.value = ''; renderResults(''); }
        matildaTriggered = false;
      }, 1000);
    };

    // ─── PIG EASTER EGG ────────────────────────────────────────────────────
    var pigTriggered = false;

    function triggerPig() {
      if (pigTriggered) return;
      pigTriggered = true;
      var overlay = document.getElementById('pigOverlay');
      if (!overlay) return;
      overlay.classList.add('active');
      document.addEventListener('keydown', function onEsc(e) {
        if (e.key === 'Escape') { dismissPig(); document.removeEventListener('keydown', onEsc); }
      });
    }

    window.dismissPig = function() {
      var overlay = document.getElementById('pigOverlay');
      if (!overlay) return;
      overlay.style.transition = 'opacity 1s ease';
      overlay.style.opacity = '0';
      setTimeout(function() {
        overlay.classList.remove('active');
        overlay.style.opacity = '';
        overlay.style.transition = '';
        var inp = document.getElementById('archiveSearch');
        if (inp) { inp.value = ''; renderResults(''); }
        pigTriggered = false;
      }, 1000);
    };

    var searchInput = document.getElementById('archiveSearch');
    searchInput.addEventListener('input', function() {
      var val = this.value.trim().toLowerCase();
      if (val === 'matilda' || val === 'matilda of halecroft') {
        triggerMatilda();
        return;
      }
      if (val === 'see to the pig') {
        triggerPig();
        return;
      }
      renderResults(this.value);
    });

    // Press / to focus the search bar
    document.addEventListener('keydown', function(e) {
      if (e.key === '/' && document.activeElement !== searchInput) {
        e.preventDefault();
        searchInput.focus();
        searchInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
      }
    });

    // Live clock in the header
    var clockEl = document.querySelector('.access-clock');
    if (clockEl) {
      function tick() {
        var now = new Date();
        var h = String(now.getHours()).padStart(2, '0');
        var m = String(now.getMinutes()).padStart(2, '0');
        clockEl.textContent = '● Access granted · ' + h + ':' + m;
      }
      tick();
      setInterval(tick, 30000);
    }

  })();
  </script>

  <script src="transitions.js"></script>

