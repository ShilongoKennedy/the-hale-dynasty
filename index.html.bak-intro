<script>
(function() {
  /* ── Archive Complete Certificate ── */
  function getPigsFound() {
    try {
      var raw = localStorage.getItem('hd_pigs_found');
      return raw ? JSON.parse(raw) : [];
    } catch(e) { return []; }
  }

  function getVolumesRead() {
    try {
      var raw = localStorage.getItem('hd_volumes_read');
      return raw ? JSON.parse(raw) : [];
    } catch(e) { return []; }
  }

  var ALL_VOLS   = ['I','II','III','IV','V','VI','VII','VIII','IX','X'];
  var ALL_PIGS   = ['I','II','III','IV','V','VI','VII','VIII','IX','X'];

  var milestones = [
    {
      key: 'volumes_visited',
      label: 'All ten volumes opened',
      check: function() { return localStorage.getItem('hale_complete') === 'true'; }
    },
    {
      key: 'volumes_read',
      label: 'All ten volumes read to 70%+',
      check: function() {
        var r = getVolumesRead();
        return ALL_VOLS.every(function(v) { return r.indexOf(v) !== -1; });
      }
    },
    {
      key: 'pigs_found',
      label: 'All ten pigs found',
      check: function() {
        var p = getPigsFound();
        return ALL_PIGS.every(function(v) { return p.indexOf(v) !== -1; });
      }
    },
    {
      key: 'cipher_solved',
      label: 'Matilda\'s cipher decoded',
      check: function() { return localStorage.getItem('hd_cipher_solved') === '1'; }
    },
    {
      key: 'confession_read',
      label: 'Edmund\'s postscript found',
      check: function() { return localStorage.getItem('hd_confession_read') === '1'; }
    }
  ];

  var milestoneEl = document.getElementById('hd-cert-milestones');
  var certEl      = document.getElementById('hd-archive-complete');
  var dateEl      = document.getElementById('hd-cert-date');

  // Count completed milestones
  var completedCount = 0;
  milestones.forEach(function(m) {
    var done = m.check();
    if (done) completedCount++;
    var row = document.createElement('div');
    row.className = 'hd-cert-milestone' + (done ? ' done' : '');
    row.innerHTML =
      '<div class="hd-cert-milestone-tick">' + (done ? '✓' : '') + '</div>' +
      '<span>' + m.label + '</span>';
    milestoneEl.appendChild(row);
  });

  // Show certificate if at least 3 milestones are complete
  // (Full display if all 5 complete; partial display shows progress otherwise)
  if (completedCount >= 3) {
    certEl.style.display = 'block';
    certEl.style.opacity = '0';
    certEl.style.transition = 'opacity 1.2s ease';
    // Record completion date
    if (completedCount >= 5) {
      if (!localStorage.getItem('hd_complete_date')) {
        try { localStorage.setItem('hd_complete_date', new Date().toLocaleDateString('en-GB', {year:'numeric',month:'long',day:'numeric'})); } catch(e){}
      }
    }
    var savedDate = '';
    try { savedDate = localStorage.getItem('hd_complete_date') || ''; } catch(e){}
    dateEl.textContent = savedDate
      ? 'Archive complete · ' + savedDate
      : completedCount + ' of 5 milestones reached · ' + new Date().getFullYear();
    // Animate in after scroll
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) {
        if (e.isIntersecting) {
          certEl.style.opacity = '1';
          io.unobserve(certEl);
        }
      });
    }, { threshold: 0.15 });
    io.observe(certEl);
  }
})();
</script>

<script src="inquiry.js"></script>
</body>
</html>
