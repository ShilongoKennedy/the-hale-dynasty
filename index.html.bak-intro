          <line x1="21" y1="8.5" x2="10" y2="17" stroke="#6A5030" stroke-width="1.2"/>
          <line x1="21" y1="8.5" x2="32" y2="17" stroke="#6A5030" stroke-width="1.2"/>
          <circle cx="10" cy="19" r="3" fill="#C8A83C" opacity="0.75"/>
          <circle cx="32" cy="19" r="3" fill="#C8A83C" opacity="0.75"/>
          <line x1="10" y1="22" x2="4"  y2="30" stroke="#6A5030" stroke-width="1"/>
