}
.hd-cert-sub {
  font-family: 'Cinzel', Georgia, serif;
  font-size: 0.8em;
  color: rgba(200,168,60,0.45);
  letter-spacing: 0.12em;
  margin-bottom: 28px;
}
.hd-cert-divider {
  border: none;
  border-top: 1px solid rgba(200,168,60,0.2);
  margin: 24px auto;
  max-width: 200px;
}
.hd-cert-body {
  font-family: Georgia, 'Times New Roman', serif;
  font-style: italic;
  font-size: 1.0em;
  color: rgba(200,168,60,0.6);
  line-height: 1.85;
  max-width: 440px;
  margin: 0 auto 28px;
}
.hd-cert-milestones {
  display: flex;
  flex-direction: column;
  gap: 8px;
  text-align: left;
  max-width: 380px;
  margin: 0 auto 30px;
}
.hd-cert-milestone {
  font-family: 'Courier New', monospace;
  font-size: 0.65em;
  letter-spacing: 0.12em;
  color: rgba(200,168,60,0.45);
  display: flex;
  align-items: center;
  gap: 10px;
}
.hd-cert-milestone.done { color: rgba(200,168,60,0.75); }
.hd-cert-milestone-tick {
  width: 16px;
  height: 16px;
  border: 1px solid rgba(200,168,60,0.3);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.85em;
  flex-shrink: 0;
}
.done .hd-cert-milestone-tick {
  background: rgba(200,168,60,0.15);
  border-color: rgba(200,168,60,0.55);
  color: rgba(200,168,60,0.9);
}
.hd-cert-date {
  font-family: 'Courier New', monospace;
  font-size: 0.6em;
  letter-spacing: 0.25em;
  color: rgba(200,168,60,0.28);
  margin-top: 24px;
  text-transform: uppercase;
}
.hd-cert-seal {
  margin: 20px auto 0;
  width: 56px;
  height: 56px;
}
</style>

<div id="hd-archive-complete">
  <div class="hd-cert">
    <div class="hd-cert-corner hd-cert-corner-tl"></div>
