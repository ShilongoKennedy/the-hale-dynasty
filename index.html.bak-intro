<style>
/* ── Certificate ── */
#hd-archive-complete {
  display: none;
  max-width: 680px;
  margin: 50px auto 70px;
  padding: 0 20px;
}
.hd-cert {
  border: 2px solid rgba(200,168,60,0.35);
  background: rgba(200,168,60,0.04);
  padding: 50px 60px;
  text-align: center;
  position: relative;
  overflow: hidden;
}
.hd-cert::before,
.hd-cert::after {
  content: '';
  position: absolute;
  inset: 8px;
  border: 1px solid rgba(200,168,60,0.12);
  pointer-events: none;
}
.hd-cert::after {
  inset: 14px;
  border-color: rgba(200,168,60,0.06);
}
.hd-cert-corner {
  position: absolute;
  width: 32px;
  height: 32px;
  border-color: rgba(200,168,60,0.4);
  border-style: solid;
}
.hd-cert-corner-tl { top: 20px; left: 20px; border-width: 1px 0 0 1px; }
.hd-cert-corner-tr { top: 20px; right: 20px; border-width: 1px 1px 0 0; }
.hd-cert-corner-bl { bottom: 20px; left: 20px; border-width: 0 0 1px 1px; }
.hd-cert-corner-br { bottom: 20px; right: 20px; border-width: 0 1px 1px 0; }

.hd-cert-glyph {
  font-size: 2.8em;
  margin-bottom: 20px;
  display: block;
  animation: cert-glyph-drift 8s ease-in-out infinite;
}
@keyframes cert-glyph-drift {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-5px); }
}
.hd-cert-label {
  font-family: 'Courier New', monospace;
  font-size: 0.62em;
  letter-spacing: 0.45em;
  text-transform: uppercase;
  color: rgba(200,168,60,0.45);
  margin-bottom: 22px;
}
.hd-cert-title {
  font-family: 'Cinzel', Georgia, serif;
  font-size: clamp(1.3em, 3.5vw, 2em);
  color: rgba(200,168,60,0.9);
  letter-spacing: 0.06em;
