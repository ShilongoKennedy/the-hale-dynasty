<script>
// ── READING PROGRESS WIDGET ──────────────────────────────────────────────
(function() {
  var ALL_VOLS = ['I','II','III','IV','V','VI','VII','VIII','IX','X'];
  var VOL_TITLES = {
    'I':'Norman · 1066', 'II':'Plague · 1348', 'III':'Tudor · 1485',
    'IV':'Civil War · 1642', 'V':'Restoration · 1671', 'VI':'Regency · 1771',
    'VII':'Victorian · 1841', 'VIII':'WWI · 1873', 'IX':'WWII · 1910', 'X':'Contemporary'
  };
  var VOL_LINKS = {
    'I':'era-I.html','II':'era-II.html','III':'era-III.html','IV':'era-IV.html',
    'V':'era-V.html','VI':'era-VI.html','VII':'era-VII.html','VIII':'era-VIII.html',
    'IX':'era-IX.html','X':'era-X.html'
  };

  function getVisited() {
    try { return JSON.parse(localStorage.getItem('hale_visited') || '[]'); } catch(e) { return []; }
  }

  function initProgress() {
    var visited = getVisited();
    if (visited.length === 0) return; // hide if no visits yet

    var section = document.getElementById('reading-progress-section');
    if (section) section.style.display = 'block';

    var pips = document.getElementById('progress-pips');
    var count = document.getElementById('progress-count');
    var next  = document.getElementById('progress-next');

    if (count) count.textContent = visited.length + ' / 10 volumes consulted';

    if (pips) {
      pips.innerHTML = '';
      ALL_VOLS.forEach(function(v) {
        var read = visited.indexOf(v) !== -1;
        var pip = document.createElement('a');
        pip.href = VOL_LINKS[v];
        pip.title = 'Vol. ' + v + ' · ' + VOL_TITLES[v];
        pip.style.cssText = [
          'flex:1; height:6px; display:block;',
          'background:' + (read ? 'rgba(200,168,60,0.55)' : 'rgba(200,168,60,0.07)') + ';',
          'border:1px solid rgba(200,168,60,' + (read ? '0.3' : '0.04') + ');',
          'transition:background 0.3s;',
          'text-decoration:none;'
        ].join('');
        pip.addEventListener('mouseenter', function() {
          this.style.background = read ? 'rgba(200,168,60,0.8)' : 'rgba(200,168,60,0.2)';
        });
        pip.addEventListener('mouseleave', function() {
          this.style.background = read ? 'rgba(200,168,60,0.55)' : 'rgba(200,168,60,0.07)';
        });
        pips.appendChild(pip);
      });
    }

    // Suggest next unread
    if (next) {
      var unread = ALL_VOLS.filter(function(v) { return visited.indexOf(v) === -1; });
      if (unread.length > 0) {
        var nv = unread[0];
        next.innerHTML = 'Next unread: <a href="' + VOL_LINKS[nv] + '" style="color:rgba(200,168,60,0.45);text-decoration:none;">Vol. ' + nv + ' · ' + VOL_TITLES[nv] + ' →</a>';
      } else {
        next.textContent = 'All ten volumes consulted. The archive is complete.';
        next.style.color = 'rgba(200,168,60,0.4)';
      }
    }

    // Also mark archive boxes as visited
    var boxes = document.querySelectorAll('.archive-box');
    boxes.forEach(function(box) {
      var href = box.getAttribute('href') || '';
      var match = href.match(/era-([IVX]+)\.html/);
      if (!match) return;
      var vol = match[1];
      if (visited.indexOf(vol) !== -1) {
        var indicator = document.createElement('div');
        indicator.style.cssText = 'position:absolute;top:8px;left:8px;width:6px;height:6px;border-radius:50%;background:rgba(200,168,60,0.5);z-index:10;';
        indicator.title = 'Consulted';
        box.style.position = 'relative';
        box.appendChild(indicator);
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initProgress);
})();
</script>

