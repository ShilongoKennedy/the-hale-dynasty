        <circle cx="24" cy="28" r="3" fill="rgba(216,192,136,0.45)"/>
        <circle cx="48" cy="28" r="3" fill="rgba(216,192,136,0.45)"/>
        <circle cx="36" cy="58" r="3" fill="rgba(216,192,136,0.45)"/>
